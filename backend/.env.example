# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Get from Neon Console → your project → Connection string
# Use "Pooled connection" for DATABASE_URL and "Direct connection" for DIRECT_URL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Frontend URL (CORS) ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
